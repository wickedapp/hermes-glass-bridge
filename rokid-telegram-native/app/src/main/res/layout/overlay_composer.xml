<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:id="@+id/composer_overlay"
    android:orientation="horizontal"
    android:layout_width="match_parent"
    android:layout_height="80px"
    android:gravity="center_vertical"
    android:background="@drawable/bg_card_stroke_80"
    android:paddingStart="12px"
    android:paddingEnd="12px"
    android:visibility="gone">

    <ImageView
        android:id="@+id/composer_mic"
        android:layout_width="@dimen/icon_reg"
        android:layout_height="@dimen/icon_reg"
        android:src="@drawable/ic_mic"
        android:contentDescription="Microphone" />

    <TextView
        android:id="@+id/composer_transcript"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_weight="1"
        android:layout_marginStart="12px"
        android:layout_marginEnd="12px"
        android:textSize="@dimen/text_l3"
        android:lineHeight="@dimen/line_l3"
        android:textColor="@color/primary_50"
        android:singleLine="true"
        android:ellipsize="end"
        android:hint="Listening…"
        android:textColorHint="@color/primary_50" />

    <ImageView
        android:id="@+id/composer_send"
        android:layout_width="@dimen/icon_reg"
        android:layout_height="@dimen/icon_reg"
        android:src="@drawable/ic_send"
        android:contentDescription="Send"
        android:visibility="gone" />

</LinearLayout>
