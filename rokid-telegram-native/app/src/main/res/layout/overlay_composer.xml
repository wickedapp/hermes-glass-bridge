<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:id="@+id/composer_overlay"
    android:orientation="vertical"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:background="@drawable/bg_card_stroke_80"
    android:focusable="true"
    android:focusableInTouchMode="false"
    android:clickable="true"
    android:paddingStart="12px"
    android:paddingEnd="12px"
    android:paddingTop="6px"
    android:paddingBottom="6px">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:gravity="center_vertical">

        <ImageView
            android:id="@+id/composer_mic"
            android:layout_width="@dimen/icon_reg"
            android:layout_height="@dimen/icon_reg"
            android:src="@drawable/ic_mic"
            android:focusable="false"
            android:contentDescription="@string/composer_mic_desc" />

        <TextView
            android:id="@+id/composer_status"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:layout_marginStart="8px"
            android:layout_marginEnd="8px"
            android:textSize="@dimen/text_l3"
            android:lineHeight="@dimen/line_l3"
            android:textColor="@color/primary_50"
            android:text="@string/composer_idle_status"
            android:singleLine="true"
            android:ellipsize="end" />

        <ImageView
            android:id="@+id/composer_send"
            android:layout_width="@dimen/icon_reg"
            android:layout_height="@dimen/icon_reg"
            android:src="@drawable/ic_send"
            android:focusable="false"
            android:visibility="gone"
            android:contentDescription="@string/composer_send_desc" />
    </LinearLayout>

    <TextView
        android:id="@+id/composer_hint"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:textSize="@dimen/text_l5"
        android:textColor="@color/primary_40"
        android:text="@string/composer_idle_hint"
        android:singleLine="true"
        android:ellipsize="end"
        android:layout_marginTop="2px" />

    <!-- Hidden by default; revealed when BT keyboard types via onPrintableKey. -->
    <EditText
        android:id="@+id/composerInput"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:textSize="@dimen/text_l3"
        android:lineHeight="@dimen/line_l3"
        android:textColor="@color/primary"
        android:textColorHint="@color/primary_50"
        android:hint="@string/composer_input_hint"
        android:background="@null"
        android:singleLine="true"
        android:focusable="false"
        android:imeOptions="actionSend"
        android:inputType="text"
        android:visibility="gone" />
</LinearLayout>
