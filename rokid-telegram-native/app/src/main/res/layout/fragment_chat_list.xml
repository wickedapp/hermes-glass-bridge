<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:background="@color/bg">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="120px"
        android:orientation="vertical"
        android:gravity="bottom"
        android:paddingStart="12px"
        android:paddingEnd="12px"
        android:paddingBottom="8px">

        <include
            android:id="@+id/header"
            layout="@layout/view_header" />

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="@string/chat_list_hint"
            android:textColor="@color/primary_50"
            android:textSize="@dimen/text_l5"
            android:lineHeight="@dimen/line_l5"
            android:singleLine="true" />
    </LinearLayout>

    <!-- Hidden compatibility search controls; current glasses UI is focus-list first. -->
    <LinearLayout
        android:id="@+id/search_bar"
        android:layout_width="0px"
        android:layout_height="0px"
        android:visibility="gone">
        <EditText
            android:id="@+id/search_input"
            android:layout_width="0px"
            android:layout_height="0px"
            android:visibility="gone" />
    </LinearLayout>

    <FrameLayout
        android:layout_width="match_parent"
        android:layout_height="400px"
        android:paddingStart="12px"
        android:paddingEnd="12px"
        android:paddingTop="6px"
        android:paddingBottom="6px">

        <androidx.recyclerview.widget.RecyclerView
            android:id="@+id/list"
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:clipToPadding="false"
            android:scrollbars="none"
            android:focusable="true"
            android:focusableInTouchMode="true" />
    </FrameLayout>

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="120px"
        android:orientation="vertical"
        android:gravity="top"
        android:paddingStart="16px"
        android:paddingEnd="16px"
        android:paddingTop="8px">

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:background="@drawable/bg_card_stroke_40"
            android:paddingStart="12px"
            android:paddingEnd="12px"
            android:paddingTop="8px"
            android:paddingBottom="8px"
            android:text="@string/chat_list_footer_title"
            android:textColor="@color/primary"
            android:textSize="@dimen/text_l4"
            android:lineHeight="@dimen/line_l4"
            android:singleLine="true" />

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="6px"
            android:text="@string/chat_list_footer_body"
            android:textColor="@color/primary_50"
            android:textSize="@dimen/text_l5"
            android:lineHeight="@dimen/line_l5"
            android:singleLine="true"
            android:ellipsize="end" />
    </LinearLayout>
</LinearLayout>
