<?xml version="1.0" encoding="utf-8"?>
<FrameLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#FF000000"
    android:defaultFocusHighlightEnabled="false"
    android:focusable="true"
    android:focusableInTouchMode="true"
    android:padding="8px">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:orientation="vertical"
        android:background="#000000"
        android:defaultFocusHighlightEnabled="false"
        android:padding="8px">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:background="#FF000000"
            android:defaultFocusHighlightEnabled="false"
            android:gravity="center_vertical"
            android:orientation="horizontal">

            <ImageView
                android:id="@+id/full_message_back"
                android:layout_width="28px"
                android:layout_height="28px"
                android:padding="4px"
                android:src="@drawable/ic_back"
                android:tint="#D0FFD0"
                android:contentDescription="@string/back" />

            <TextView
                android:id="@+id/full_message_title"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:ellipsize="end"
                android:fontFamily="monospace"
                android:maxLines="1"
                android:paddingStart="8px"
                android:paddingEnd="4px"
                android:textColor="#D0FFD0"
                android:textSize="14px"
                android:textStyle="bold" />
        </LinearLayout>

        <ScrollView
            android:id="@+id/full_message_scroll"
            android:layout_width="match_parent"
            android:layout_height="0dp"
            android:layout_marginTop="6px"
            android:layout_weight="1"
            android:background="#FF000000"
            android:defaultFocusHighlightEnabled="false"
            android:fadeScrollbars="false"
            android:fillViewport="true"
            android:focusable="false"
            android:focusableInTouchMode="false"
            android:overScrollMode="never"
            android:scrollbars="none">

            <TextView
                android:id="@+id/full_message_text"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:background="#FF000000"
                android:defaultFocusHighlightEnabled="false"
                android:focusable="false"
                android:fontFamily="monospace"
                android:lineSpacingExtra="2px"
                android:textColor="#E8FFE8"
                android:textIsSelectable="false"
                android:textSize="14px" />
        </ScrollView>
    </LinearLayout>
</FrameLayout>
