<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:orientation="vertical"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/bg">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="84px"
        android:orientation="vertical"
        android:gravity="bottom"
        android:paddingStart="12px"
        android:paddingEnd="12px"
        android:paddingBottom="4px">

        <include
            android:id="@+id/header"
            layout="@layout/view_header" />

        <TextView
            android:id="@+id/mode_hint"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="↑↓換窗口 · Enter 進入 · Back 返回"
            android:textColor="@color/primary_50"
            android:textSize="@dimen/text_l5"
            android:lineHeight="@dimen/line_l5"
            android:singleLine="true" />
    </LinearLayout>

    <TextView
        android:id="@+id/peer"
        android:layout_width="0dp"
        android:layout_height="0dp"
        android:visibility="gone" />

    <FrameLayout
        android:id="@+id/message_window"
        android:layout_width="match_parent"
        android:layout_height="468px"
        android:background="@drawable/bg_card_row_state"
        android:focusable="true"
        android:focusableInTouchMode="true"
        android:clickable="true"
        android:paddingStart="6px"
        android:paddingEnd="6px"
        android:paddingTop="6px"
        android:paddingBottom="6px">

        <androidx.recyclerview.widget.RecyclerView
            android:id="@+id/messages"
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:clipToPadding="false"
            android:scrollbars="none"
            android:focusable="false"
            android:focusableInTouchMode="false"
            android:descendantFocusability="afterDescendants" />
    </FrameLayout>

    <FrameLayout
        android:id="@+id/reply_window"
        android:layout_width="match_parent"
        android:layout_height="88px"
        android:background="@color/bg"
        android:focusable="true"
        android:focusableInTouchMode="true"
        android:clickable="true"
        android:paddingStart="12px"
        android:paddingEnd="12px"
        android:paddingTop="8px"
        android:paddingBottom="8px">

        <include
            layout="@layout/overlay_reply"
            android:layout_width="match_parent"
            android:layout_height="wrap_content" />
    </FrameLayout>
</LinearLayout>
