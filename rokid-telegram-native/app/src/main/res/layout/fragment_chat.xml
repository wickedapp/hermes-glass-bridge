<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:orientation="vertical"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#000000">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="126px"
        android:orientation="vertical"
        android:gravity="bottom"
        android:paddingStart="10px"
        android:paddingEnd="10px"
        android:paddingBottom="4px">

        <include
            android:id="@+id/header"
            layout="@layout/view_header" />

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="TIME  NAME     MESSAGE"
            android:textColor="@color/primary_50"
            android:textSize="12px"
            android:fontFamily="monospace"
            android:singleLine="true" />

        <TextView
            android:id="@+id/mode_hint"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="@string/chat_hint_focus_default"
            android:textColor="@color/primary_50"
            android:textSize="12px"
            android:fontFamily="monospace"
            android:singleLine="true" />
    </LinearLayout>

    <TextView
        android:id="@+id/peer"
        android:layout_width="0dp"
        android:layout_height="0dp"
        android:visibility="gone" />

    <FrameLayout
        android:id="@+id/message_window"
        android:layout_width="match_parent"
        android:layout_height="396px"
        android:background="#000000"
        android:focusable="true"
        android:focusableInTouchMode="true"
        android:clickable="true"
        android:paddingStart="8px"
        android:paddingEnd="8px"
        android:paddingTop="4px"
        android:paddingBottom="4px">

        <androidx.recyclerview.widget.RecyclerView
            android:id="@+id/messages"
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:background="#000000"
            android:clipToPadding="false"
            android:scrollbars="none"
            android:focusable="false"
            android:focusableInTouchMode="false"
            android:descendantFocusability="afterDescendants" />
    </FrameLayout>

    <FrameLayout
        android:id="@+id/reply_window"
        android:layout_width="match_parent"
        android:layout_height="118px"
        android:background="#000000"
        android:focusable="true"
        android:focusableInTouchMode="true"
        android:clickable="true"
        android:paddingStart="12px"
        android:paddingEnd="12px"
        android:paddingTop="6px"
        android:paddingBottom="6px">

        <include
            layout="@layout/overlay_reply"
            android:layout_width="match_parent"
            android:layout_height="wrap_content" />
    </FrameLayout>
</LinearLayout>
