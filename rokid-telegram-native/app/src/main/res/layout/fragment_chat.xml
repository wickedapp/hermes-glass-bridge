<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:orientation="vertical"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/bg">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="120px"
        android:orientation="vertical"
        android:gravity="bottom"
        android:paddingStart="12px"
        android:paddingEnd="12px"
        android:paddingBottom="8px">

        <include
            android:id="@+id/header"
            layout="@layout/view_header" />

        <TextView
            android:id="@+id/mode_hint"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="焦點模式：↑↓換窗口 · Enter 進入窗口 · Back 返回列表"
            android:textColor="@color/primary_50"
            android:textSize="@dimen/text_l5"
            android:lineHeight="@dimen/line_l5"
            android:singleLine="true" />
    </LinearLayout>

    <TextView
        android:id="@+id/peer"
        android:layout_width="0dp"
        android:layout_height="0dp"
        android:visibility="gone" />

    <FrameLayout
        android:id="@+id/message_window"
        android:layout_width="match_parent"
        android:layout_height="360px"
        android:background="@drawable/bg_card_row_state"
        android:focusable="true"
        android:focusableInTouchMode="true"
        android:clickable="true"
        android:paddingStart="10px"
        android:paddingEnd="10px"
        android:paddingTop="4px"
        android:paddingBottom="4px">

        <androidx.recyclerview.widget.RecyclerView
            android:id="@+id/messages"
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:clipToPadding="false"
            android:scrollbars="none"
            android:focusable="false"
            android:focusableInTouchMode="false"
            android:descendantFocusability="afterDescendants" />
    </FrameLayout>

    <LinearLayout
        android:id="@+id/reply_window"
        android:layout_width="match_parent"
        android:layout_height="160px"
        android:orientation="vertical"
        android:gravity="top"
        android:background="@drawable/bg_card_row_state"
        android:focusable="true"
        android:focusableInTouchMode="true"
        android:clickable="true"
        android:paddingStart="12px"
        android:paddingEnd="12px"
        android:paddingTop="6px">

        <include
            layout="@layout/overlay_reply"
            android:layout_width="match_parent"
            android:layout_height="wrap_content" />

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="6px"
            android:text="回覆窗口：Enter 開啟 · 語音轉文字先確認，不自動送出"
            android:textColor="@color/primary_50"
            android:textSize="@dimen/text_l5"
            android:lineHeight="@dimen/line_l5"
            android:singleLine="true"
            android:ellipsize="end" />
    </LinearLayout>
</LinearLayout>
