<FrameLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:id="@+id/reply_panel"
    android:layout_width="match_parent"
    android:layout_height="wrap_content">

    <!-- State: DEFAULT — single Reply button -->
    <LinearLayout
        android:id="@+id/state_default"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:gravity="center">

        <TextView
            android:id="@+id/btn_reply"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:minWidth="120px"
            android:gravity="center"
            android:text="@string/btn_reply"
            android:textSize="@dimen/text_l3"
            android:lineHeight="@dimen/line_l3"
            android:textColor="@color/primary"
            android:background="@drawable/bg_card_row_state"
            android:paddingStart="16px"
            android:paddingEnd="16px"
            android:paddingTop="8px"
            android:paddingBottom="8px"
            android:focusable="true"
            android:focusableInTouchMode="false"
            android:clickable="true" />
    </LinearLayout>

    <!-- State: MENU — Voice / Text / BT -->
    <LinearLayout
        android:id="@+id/state_menu"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:visibility="gone">

        <TextView
            android:id="@+id/btn_voice"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:layout_marginEnd="4px"
            android:gravity="center"
            android:text="@string/btn_voice"
            android:textSize="@dimen/text_l3"
            android:lineHeight="@dimen/line_l3"
            android:textColor="@color/primary"
            android:background="@drawable/bg_card_row_state"
            android:paddingTop="8px"
            android:paddingBottom="8px"
            android:focusable="true"
            android:focusableInTouchMode="false"
            android:clickable="true" />

        <TextView
            android:id="@+id/btn_text"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:layout_marginStart="4px"
            android:layout_marginEnd="4px"
            android:gravity="center"
            android:text="@string/btn_text"
            android:textSize="@dimen/text_l3"
            android:lineHeight="@dimen/line_l3"
            android:textColor="@color/primary"
            android:background="@drawable/bg_card_row_state"
            android:paddingTop="8px"
            android:paddingBottom="8px"
            android:focusable="true"
            android:focusableInTouchMode="false"
            android:clickable="true" />

        <TextView
            android:id="@+id/btn_bt"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:layout_marginStart="4px"
            android:gravity="center"
            android:text="@string/btn_bt"
            android:textSize="@dimen/text_l3"
            android:lineHeight="@dimen/line_l3"
            android:textColor="@color/primary"
            android:background="@drawable/bg_card_row_state"
            android:paddingTop="8px"
            android:paddingBottom="8px"
            android:focusable="true"
            android:focusableInTouchMode="false"
            android:clickable="true" />
    </LinearLayout>

    <!-- State: VOICE RECORDING — live status + Send / Cancel -->
    <LinearLayout
        android:id="@+id/state_voice"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:gravity="center_vertical"
        android:visibility="gone">

        <TextView
            android:id="@+id/voice_status"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:paddingStart="8px"
            android:textSize="@dimen/text_l3"
            android:lineHeight="@dimen/line_l3"
            android:textColor="@color/primary"
            android:text="@string/voice_recording_zero" />

        <TextView
            android:id="@+id/btn_voice_send"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:minWidth="80px"
            android:gravity="center"
            android:text="@string/btn_send"
            android:textSize="@dimen/text_l3"
            android:textColor="@color/primary"
            android:background="@drawable/bg_card_row_state"
            android:paddingStart="12px"
            android:paddingEnd="12px"
            android:paddingTop="8px"
            android:paddingBottom="8px"
            android:layout_marginEnd="4px"
            android:focusable="true"
            android:clickable="true" />

        <TextView
            android:id="@+id/btn_voice_cancel"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:minWidth="80px"
            android:gravity="center"
            android:text="@string/btn_cancel"
            android:textSize="@dimen/text_l3"
            android:textColor="@color/primary_50"
            android:background="@drawable/bg_card_row_state"
            android:paddingStart="12px"
            android:paddingEnd="12px"
            android:paddingTop="8px"
            android:paddingBottom="8px"
            android:focusable="true"
            android:clickable="true" />
    </LinearLayout>

    <!-- State: TEXT (voice-to-text) — transcript + Send / Cancel -->
    <LinearLayout
        android:id="@+id/state_text"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:visibility="gone">

        <TextView
            android:id="@+id/text_transcript"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:textSize="@dimen/text_l3"
            android:lineHeight="@dimen/line_l3"
            android:textColor="@color/primary_50"
            android:text="@string/composer_listening"
            android:paddingStart="8px"
            android:paddingEnd="8px"
            android:paddingBottom="4px"
            android:maxLines="2"
            android:ellipsize="end" />

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal">

            <TextView
                android:id="@+id/btn_text_send"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:layout_marginEnd="4px"
                android:gravity="center"
                android:text="@string/btn_send"
                android:textSize="@dimen/text_l3"
                android:textColor="@color/primary"
                android:background="@drawable/bg_card_row_state"
                android:paddingTop="8px"
                android:paddingBottom="8px"
                android:focusable="true"
                android:clickable="true" />

            <TextView
                android:id="@+id/btn_text_cancel"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:layout_marginStart="4px"
                android:gravity="center"
                android:text="@string/btn_cancel"
                android:textSize="@dimen/text_l3"
                android:textColor="@color/primary_50"
                android:background="@drawable/bg_card_row_state"
                android:paddingTop="8px"
                android:paddingBottom="8px"
                android:focusable="true"
                android:clickable="true" />
        </LinearLayout>
    </LinearLayout>

    <!-- State: BT INPUT — EditText + Send -->
    <LinearLayout
        android:id="@+id/state_bt"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:gravity="center_vertical"
        android:visibility="gone">

        <EditText
            android:id="@+id/bt_input"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:textSize="@dimen/text_l3"
            android:lineHeight="@dimen/line_l3"
            android:textColor="@color/primary"
            android:textColorHint="@color/primary_50"
            android:hint="@string/composer_input_hint"
            android:background="@drawable/bg_card_row_state"
            android:paddingStart="10px"
            android:paddingEnd="10px"
            android:paddingTop="6px"
            android:paddingBottom="6px"
            android:singleLine="true"
            android:imeOptions="actionSend"
            android:inputType="text" />

        <TextView
            android:id="@+id/btn_bt_send"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:minWidth="64px"
            android:gravity="center"
            android:text="@string/btn_send"
            android:textSize="@dimen/text_l3"
            android:textColor="@color/primary"
            android:background="@drawable/bg_card_row_state"
            android:paddingStart="10px"
            android:paddingEnd="10px"
            android:paddingTop="6px"
            android:paddingBottom="6px"
            android:layout_marginStart="4px"
            android:focusable="true"
            android:clickable="true" />
    </LinearLayout>

</FrameLayout>
