<FrameLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:id="@+id/reply_panel"
    android:layout_width="match_parent"
    android:layout_height="wrap_content">

    <LinearLayout
        android:id="@+id/state_default"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:gravity="center">
        <TextView
            android:id="@+id/btn_reply"
            android:layout_width="match_parent"
            android:layout_height="44px"
            android:gravity="center"
            android:text="Reply"
            android:textSize="@dimen/text_l4"
            android:lineHeight="@dimen/line_l4"
            android:textColor="@color/primary"
            android:background="@drawable/bg_card_row_state"
            android:focusable="true"
            android:focusableInTouchMode="false"
            android:clickable="true" />
    </LinearLayout>

    <LinearLayout
        android:id="@+id/state_menu"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:visibility="gone">
        <TextView android:id="@+id/btn_voice" android:layout_width="0dp" android:layout_height="44px" android:layout_weight="1" android:layout_marginEnd="4px" android:gravity="center" android:text="Voice" android:textSize="@dimen/text_l5" android:textColor="@color/primary" android:background="@drawable/bg_card_row_state" android:focusable="true" android:clickable="true" />
        <TextView android:id="@+id/btn_text" android:layout_width="0dp" android:layout_height="44px" android:layout_weight="1" android:layout_marginStart="4px" android:layout_marginEnd="4px" android:gravity="center" android:text="Dictate" android:textSize="@dimen/text_l5" android:textColor="@color/primary" android:background="@drawable/bg_card_row_state" android:focusable="true" android:clickable="true" />
        <TextView android:id="@+id/btn_bt" android:layout_width="0dp" android:layout_height="44px" android:layout_weight="1" android:layout_marginStart="4px" android:gravity="center" android:text="Keyboard" android:textSize="@dimen/text_l5" android:textColor="@color/primary" android:background="@drawable/bg_card_row_state" android:focusable="true" android:clickable="true" />
    </LinearLayout>

    <LinearLayout
        android:id="@+id/state_voice"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:gravity="center_vertical"
        android:visibility="gone">
        <TextView android:id="@+id/voice_status" android:layout_width="0dp" android:layout_height="44px" android:layout_weight="1" android:gravity="center_vertical" android:paddingStart="10px" android:textSize="@dimen/text_l4" android:textColor="@color/primary" android:text="@string/voice_recording_zero" android:background="@drawable/bg_card_stroke_40" />
        <TextView android:id="@+id/btn_voice_send" android:layout_width="76px" android:layout_height="44px" android:layout_marginStart="5px" android:gravity="center" android:text="Send" android:textSize="@dimen/text_l5" android:textColor="@color/primary" android:background="@drawable/bg_card_row_state" android:focusable="true" android:clickable="true" />
        <TextView android:id="@+id/btn_voice_cancel" android:layout_width="76px" android:layout_height="44px" android:layout_marginStart="5px" android:gravity="center" android:text="Cancel" android:textSize="@dimen/text_l5" android:textColor="@color/primary_50" android:background="@drawable/bg_card_row_state" android:focusable="true" android:clickable="true" />
    </LinearLayout>

    <LinearLayout
        android:id="@+id/state_text"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:visibility="gone">
        <TextView android:id="@+id/text_transcript" android:layout_width="match_parent" android:layout_height="48px" android:textSize="@dimen/text_l5" android:lineHeight="@dimen/line_l5" android:textColor="@color/primary_50" android:text="@string/composer_listening" android:paddingStart="10px" android:paddingEnd="10px" android:paddingTop="4px" android:paddingBottom="4px" android:background="@drawable/bg_card_stroke_40" android:maxLines="2" android:ellipsize="end" />
        <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content" android:layout_marginTop="6px" android:orientation="horizontal">
            <TextView android:id="@+id/btn_text_send" android:layout_width="0dp" android:layout_height="36px" android:layout_weight="1" android:layout_marginEnd="5px" android:gravity="center" android:text="Send" android:textSize="@dimen/text_l5" android:textColor="@color/primary" android:background="@drawable/bg_card_row_state" android:focusable="true" android:clickable="true" />
            <TextView android:id="@+id/btn_text_cancel" android:layout_width="0dp" android:layout_height="36px" android:layout_weight="1" android:layout_marginStart="5px" android:gravity="center" android:text="Redo/Cancel" android:textSize="@dimen/text_l5" android:textColor="@color/primary_50" android:background="@drawable/bg_card_row_state" android:focusable="true" android:clickable="true" />
        </LinearLayout>
    </LinearLayout>

    <LinearLayout
        android:id="@+id/state_bt"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:gravity="center_vertical"
        android:visibility="gone">
        <EditText android:id="@+id/bt_input" android:layout_width="0dp" android:layout_height="44px" android:layout_weight="1" android:textSize="@dimen/text_l5" android:textColor="@color/primary" android:textColorHint="@color/primary_50" android:hint="@string/composer_input_hint" android:background="@drawable/bg_card_row_state" android:paddingStart="10px" android:paddingEnd="10px" android:singleLine="true" android:imeOptions="actionSend" android:inputType="text" />
        <TextView android:id="@+id/btn_bt_send" android:layout_width="76px" android:layout_height="44px" android:layout_marginStart="5px" android:gravity="center" android:text="Send" android:textSize="@dimen/text_l5" android:textColor="@color/primary" android:background="@drawable/bg_card_row_state" android:focusable="true" android:clickable="true" />
    </LinearLayout>
</FrameLayout>
